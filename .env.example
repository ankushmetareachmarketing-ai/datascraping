# ─────────────────────────────────────────────────────────────
# Lead Agent — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── Google Places API ──────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# ── SerpAPI (fallback search) ──────────────────────────────
# Get from: https://serpapi.com/dashboard
SERPAPI_KEY=your_serpapi_key_here

# ── Google Sheets Integration (optional) ──────────────────
# Service account JSON key path
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/google_service_account.json

# Spreadsheet ID from the Google Sheets URL
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# ── App Settings ───────────────────────────────────────────
MAX_WORKERS=5            # Parallel scraping threads
REQUEST_TIMEOUT=15       # Seconds per HTTP request
MAX_RESULTS_PER_CITY=100 # Cap per city/category search
ENABLE_PLAYWRIGHT=true   # Set false if Playwright not installed
LOG_LEVEL=INFO
